# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Model Settings ────────────────────────────────────────────────────────────
# Leave blank to use the provider default (see src/agent/config.py)
MODEL_NAME=
TEMPERATURE=0

# ─── Adapters ─────────────────────────────────────────────────────────────────
# Comma-separated list of adapters to start.
# Omit this line (or leave unset) to enable all three.
# Set to empty string to disable all adapters (useful for library-only use).
# ENABLED_ADAPTERS=terminal,discord,heartbeat

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications and copy the token here.
# If unset, the Discord adapter is skipped even if "discord" is in ENABLED_ADAPTERS.
DISCORD_BOT_TOKEN=

# ─── Heartbeat ────────────────────────────────────────────────────────────────
# How often the heartbeat runs (seconds). Default: 600 (10 minutes).
HEARTBEAT_INTERVAL_SECONDS=600

# Path to the Markdown file sent to the agent on every tick. Default: HEARTBEAT.md
HEARTBEAT_PROMPT_FILE=HEARTBEAT.md

# Forward heartbeat responses to another adapter (e.g. a Discord monitoring channel).
# Both values must be set together; leave blank to log only.
#
# Example — send heartbeat output to a Discord channel:
#   HEARTBEAT_OUTPUT_ADAPTER=discord
#   HEARTBEAT_OUTPUT_CHANNEL=<your-discord-channel-id>
HEARTBEAT_OUTPUT_ADAPTER=
HEARTBEAT_OUTPUT_CHANNEL=

# ─── Optional Tools ────────────────────────────────────────────────────────────
# Tavily web search — https://app.tavily.com/
# If set, the agent gains a live web_search tool automatically.
TAVILY_API_KEY=tvly-...

# ─── LangSmith Tracing (optional but recommended) ──────────────────────────────
# https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agent-dev
