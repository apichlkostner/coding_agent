# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Model Settings ────────────────────────────────────────────────────────────
# Leave blank to use the provider default (see src/agent/config.py)
MODEL_NAME=
TEMPERATURE=0

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications and copy the token here.
# Leave blank to skip the Discord bot and run the terminal interface only.
DISCORD_TOKEN=

# ─── Optional Tools ────────────────────────────────────────────────────────────
# Tavily web search — https://app.tavily.com/
# If set, the agent gains a live web_search tool automatically.
TAVILY_API_KEY=tvly-...

# ─── LangSmith Tracing (optional but recommended) ──────────────────────────────
# https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agent-dev
